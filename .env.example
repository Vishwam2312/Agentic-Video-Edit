# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="ExplainAI Video Engine"
APP_VERSION="0.1.0"
DEBUG=false

# ── CORS (JSON array) ─────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=explainai

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_ROOT=storage

# ── OpenAI / LLM ─────────────────────────────────────────────────────────────
# Use OpenAI directly:
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Or point at any OpenAI-compatible endpoint (Ollama, Together.ai, LiteLLM…):
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama   # Ollama ignores the key but the SDK requires one

# ── Coqui TTS ───────────────────────────────────────────────────────────────
# TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
# List all models: python -c "from TTS.api import TTS; print(TTS().list_models())"

# ── FFmpeg ───────────────────────────────────────────────────────────────
# Leave empty to use ffmpeg from system PATH, or set an explicit path:
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
