# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Mypy / type checkers ──────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Storage (runtime-generated files, keep directory structure via .gitkeep) ──
storage/uploads/*
storage/scripts/*
storage/scenes/*
storage/animations/*
storage/audio/*
storage/videos/*
storage/final/*
!storage/**/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Node.js / Next.js ─────────────────────────────────────────────────────────
node_modules/
.next/
out/
studio-ui/.env.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
